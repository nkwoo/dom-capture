{
  "manifest_version": 3,
  "name": "DOM Capture",
  "version": "1.0.0",
  "description": "Capture DOM elements or full pages as PNG or PDF",
  "permissions": ["activeTab", "tabs", "downloads", "clipboardWrite", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/jspdf.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
